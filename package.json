{
  "name": "kpvotes-ts",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4"
  },
  "dependencies": {
    "@datalust/winston-seq": "^3.0.1",
    "@lightpanda/browser": "^1.3.1",
    "@stdray-npm/petbox-client": "^0.1.0-ci.325",
    "cheerio": "^1.2.0",
    "https-proxy-agent": "^9.1.0",
    "playwright-core": "^1.60.0",
    "socks-proxy-agent": "^10.1.0",
    "twitter-api-v2": "^1.29.0",
    "winston": "^3.19.0"
  },
  "scripts": {
    "build": "tsup",
    "start": "npm run build && node dist/index.js",
    "bootstrap": "npm run build && node dist/bootstrap.js",
    "check": "tsc --noEmit",
    "test": "vitest run --exclude 'tests/integration/**'",
    "test:integration": "vitest run tests/integration/",
    "lint": "npx @biomejs/biome check src/ tests/",
    "format": "npx @biomejs/biome format --write src/ tests/"
  }
