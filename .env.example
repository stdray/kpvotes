# PetBox bootstrap — all app config (incl. secrets) and the votes cache come from PetBox.
# Get a project-scoped key (config:read, data:*, logs:ingest/query, health:write) from
# the PetBox "Connect agent" page.
PETBOX_ENDPOINT=https://petbox.3po.su
PETBOX_API_KEY=<your-petbox-api-key>

# Optional overrides:
# PETBOX_DATA_DB=kpvotes-cache      # cache DataDb name (default: kpvotes-cache)
# KPVOTES_LOG_LEVEL=info            # winston level (info|debug|warn|error)
# KPVOTES_DATA_PATH=data            # local dir for page dumps when dump-pages=true
